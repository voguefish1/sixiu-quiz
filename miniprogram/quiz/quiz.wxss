.container{padding:20rpx;}
.exam-banner{background:#fff3cd;border:1px solid #ffc107;border-radius:12rpx;padding:16rpx;text-align:center;font-size:24rpx;color:#856404;margin-bottom:16rpx;}
.quiz-card{background:#fff;border-radius:24rpx;padding:32rpx;}
.meta{display:flex;gap:12rpx;margin-bottom:20rpx;align-items:center;}
.badge{padding:4rpx 16rpx;border-radius:20rpx;font-size:22rpx;font-weight:600;}
.badge-ch{background:#e8f0fe;color:#1967d2;}
.badge-type{background:#fce8e6;color:#d93025;}
.badge-diff{background:#e6f4ea;color:#137333;}
.progress{font-size:24rpx;color:#888;margin-left:auto;}
.q-text{font-size:32rpx;line-height:1.8;margin-bottom:24rpx;}
.hint{font-size:24rpx;color:#888;margin-bottom:12rpx;display:block;}
.opt{padding:24rpx;border:2rpx solid #e0e0e0;border-radius:16rpx;margin-bottom:12rpx;display:flex;align-items:center;gap:16rpx;}
.opt.selected{border-color:#667eea;background:#ede7f6;}
.opt-label{width:48rpx;height:48rpx;border-radius:50%;background:#f0f0f0;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:26rpx;}
.opt.selected .opt-label{background:#667eea;color:#fff;}
.submit-btn{background:#667eea;color:#fff;border-radius:50rpx;margin-top:16rpx;}
.feedback{padding:24rpx;border-radius:16rpx;margin-top:16rpx;font-weight:600;}
.feedback.correct{background:#e6f4ea;color:#137333;}
.feedback.wrong{background:#fce8e6;color:#c5221f;}
.nav-row{display:flex;gap:12rpx;margin-top:24rpx;}
.nav-btn{flex:1;border-radius:50rpx;font-size:26rpx;border:2rpx solid #e0e0e0;background:#fff;}
.nav-btn.primary{background:#667eea;color:#fff;border-color:#667eea;}
.nav-btn.danger{background:#ea4335;color:#fff;border-color:#ea4335;}
.nav-panel{background:#fff;border-radius:24rpx;padding:24rpx;margin-top:20rpx;}
.panel-title{font-size:28rpx;color:#555;text-align:center;margin-bottom:16rpx;}
.dot-grid{display:flex;flex-wrap:wrap;gap:12rpx;}
.dot{width:60rpx;height:60rpx;border-radius:12rpx;border:2rpx solid #ddd;display:flex;align-items:center;justify-content:center;font-size:24rpx;}
.dot.current{background:#667eea;color:#fff;border-color:#667eea;}
.dot.answered{background:#e8e8e8;color:#888;}
.dot.answered.current{background:#667eea;color:#fff;}
.dot-stats{display:flex;justify-content:space-between;margin-top:16rpx;font-size:24rpx;color:#888;}
