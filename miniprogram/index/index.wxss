.container{padding:20rpx;}
.header{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;padding:40rpx;border-radius:24rpx;text-align:center;margin-bottom:24rpx;}
.title{font-size:40rpx;font-weight:700;}
.sub{font-size:24rpx;opacity:.85;margin-top:8rpx;display:block;}
.card{background:#fff;border-radius:24rpx;padding:32rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);}
.section-title{font-size:28rpx;color:#333;font-weight:600;margin:24rpx 0 16rpx;}
.chip-row{display:flex;gap:12rpx;white-space:nowrap;}
.chip-row.wrap{flex-wrap:wrap;}
.chip{padding:12rpx 28rpx;border-radius:40rpx;border:2rpx solid #e0e0e0;font-size:26rpx;flex-shrink:0;}
.chip.active{background:#667eea;color:#fff;border-color:#667eea;}
.mode-row{display:flex;gap:16rpx;}
.mode-btn{flex:1;text-align:center;padding:20rpx;border-radius:40rpx;border:2rpx solid #e0e0e0;font-size:28rpx;}
.mode-btn.active{background:#667eea;color:#fff;border-color:#667eea;}
.start-btn{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-radius:50rpx;margin-top:32rpx;font-size:32rpx;font-weight:600;}
